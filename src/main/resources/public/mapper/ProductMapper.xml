<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vgbhfive.v_rule.mapper.ProductMapper">

    <update id="updateDeployTimeBatch">
        UPDATE product
        SET deploy_at = #{deployTime}
        WHERE product_no IN
        <foreach collection="productNos" item="no" open="(" separator="," close=")">
            #{no}
        </foreach>
        AND is_delete = 0
    </update>

</mapper>
