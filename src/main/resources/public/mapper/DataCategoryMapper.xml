<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vgbhfive.v_rule.mapper.DataCategoryMapper">

    <resultMap id="queryDetailById" type="com.vgbhfive.v_rule.entity.DataCategoryEntity">
        <id property="id" column="id"/>
        <result property="lineNo" column="line_no"/>
        <result property="dataCategoryName" column="data_category_name"/>
        <result property="dataCategoryNo" column="data_category_no"/>
        <result property="sourceFrom" column="source_from"/>
        <result property="sourceType" column="source_type"/>
        <result property="categoryType" column="category_type"/>
        <result property="priority" column="priority"/>
        <result property="version" column="version"/>
        <result property="isValid" column="is_valid"/>
        <result property="isDelete" column="is_delete"/>
        <result property="createAt" column="create_at"/>
        <collection property="detailList" javaType="List" ofType="com.vgbhfive.v_rule.entity.DataCategoryDetailEntity">
            <result property="key" column="key"/>
            <result property="valueType" column="value_type"/>
            <result property="value" column="value"/>
            <result property="trialValue" column="trial_value"/>
        </collection>
    </resultMap>

    <select id="queryList" resultType="com.vgbhfive.v_rule.dto.datacategory.DataCategoryListDto">
        SELECT
            id, line_no, data_category_name, data_category_no, source_from, source_type, category_type, priority, version, is_valid, create_at
        FROM data_category
        <trim prefix="WHERE" prefixOverrides="AND">
            <if test="param.lineNo != null and param.lineNo != ''">
                line_no = #{param.lineNo}
            </if>
            <if test="param.dataCategoryName != null and param.dataCategoryName != ''">
                AND data_category_name like CONCAT(#{param.dataCategoryName}, '%')
            </if>
            <if test="param.dataCategoryNo != null and param.dataCategoryNo != ''">
                AND data_category_no = #{param.dataCategoryNo}
            </if>
            <if test="param.isValid != null">
                AND is_valid = #{param.isValid}
            </if>
            AND is_delete = 0
        </trim>
        ORDER BY create_at DESC
        LIMIT #{start}, #{limit}
    </select>

    <select id="queryTotalCount" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM data_category
        <trim prefix="WHERE" prefixOverrides="AND">
            <if test="param.lineNo != null and param.lineNo != ''">
                line_no = #{param.lineNo}
            </if>
            <if test="param.dataCategoryName != null and param.dataCategoryName != ''">
                AND data_category_name like CONCAT(#{param.dataCategoryName}, '%')
            </if>
            <if test="param.dataCategoryNo != null and param.dataCategoryNo != ''">
                AND data_category_no = #{param.dataCategoryNo}
            </if>
            <if test="param.isValid != null">
                AND is_valid = #{param.isValid}
            </if>
            AND is_delete = 0
        </trim>
    </select>

    <select id="queryDetailById" resultMap="queryDetailById">
        SELECT d.*, dd.key, dd.value_type, dd.value, dd.trial_value
        FROM data_category d
        LEFT JOIN data_category_detail dd ON d.data_category_no = dd.data_category_no
        WHERE d.id = #{id} AND d.is_delete = 0 AND dd.is_delete = 0
    </select>

    <select id="queryDataCategoryByDataCategoryNos" resultType="com.vgbhfive.v_rule.dto.deploy.SceneStruct$DataCategory">
        SELECT data_category_no as no, data_category_name as name, source_from, source_type, category_type, priority, version, is_valid
        FROM data_category
        WHERE data_category_no IN
        <foreach collection="dataCategoryNos" item="no" open="(" separator="," close=")">
            #{no}
        </foreach>
        AND is_delete = 0 AND is_valid = 1
    </select>

    <select id="selectDropdownList" resultType="com.vgbhfive.v_rule.dto.DropdownList">
        SELECT data_category_no as value, data_category_name as `key`
        FROM data_category
        <trim prefix="WHERE" prefixOverrides="AND">
            <if test="lineNo != null and lineNo != ''">
                line_no = #{lineNo}
            </if>
            AND is_valid = 1 AND is_delete = 0
        </trim>
    </select>

</mapper>
